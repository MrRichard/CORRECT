@startuml

package "Docker Container / System" {
    
    component "NETRT Application" {
        component "Main Loop" as Main
        component "DICOM Listener\n(pynetdicom)" as Listener
        component "Study Processor" as Processor
        component "File System Watcher\n(watchdog)" as Watcher
        component "Processing Pipeline" {
            [Contour Processor]
            [Anonymizer]
            [Burn-in Processor]
        }
    }

    database "Local File System" {
        folder "Working Directory" {
            [Incoming Studies]
            [Quarantine]
        }
        file "Logs"
        file "Config.yaml"
    }

}

cloud "External Systems" {
    [CT Scanner / TPS] as Source
    [PACS / Archive] as Destination
}

Source --> Listener : DICOM Association (C-STORE)
Listener --> [Incoming Studies] : Writes Files
Watcher ..> [Incoming Studies] : Monitors
Watcher --> Main : Triggers Event
Main --> Processor : Initiates
Processor --> [Incoming Studies] : Reads/Modifies
Processor --> [Contour Processor] : Uses
Processor --> [Anonymizer] : Uses
Processor --> Destination : DICOM Association (C-STORE)

Config.yaml ..> Main : Configures
Logs <.. Main : Writes

@enduml
