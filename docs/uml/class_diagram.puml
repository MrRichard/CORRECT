@startuml

package "netrt_core" {
    class ConfigLoader {
        +load_config(config_path: str): dict
    }

    class DicomListener {
        -host: str
        -port: int
        -ae_title: str
        -study_processor_callback: callable
        -file_system_manager: FileSystemManager
        -ae: pynetdicom.AE
        -study_senders: dict
        +__init__(host, port, ae_title, study_processor_callback, file_system_manager, config)
        +start()
        +stop()
        -_configure_ae()
        -_handle_association_accepted(event)
        -_handle_echo(event)
        -_handle_store(event)
        -_handle_conn_close(event)
    }

    class FileSystemManager {
        -config: dict
        -working_dir: str
        -quarantine_dir: str
        -logs_dir: str
        -processing_locks: dict
        -observer: watchdog.observers.Observer
        -event_handler: NewStudyEventHandler
        +__init__(config, study_processor_callback)
        +start_watching()
        +stop_watching()
        +get_study_path(study_instance_uid): str
        +save_incoming_dicom(dataset, file_meta, negotiated_ts): str
        +quarantine_study(study_instance_uid, reason)
        +cleanup_study_directory(study_instance_uid)
        +is_study_being_processed(study_uid): bool
        +acquire_study_lock(study_uid): bool
        +release_study_lock(study_uid)
    }

    class NewStudyEventHandler {
        -fsm: FileSystemManager
        -study_processor_callback: callable
        -study_activity_timers: dict
        -debounce_interval: int
        -min_file_count_for_processing: int
        +on_created(event)
        +on_modified(event)
        +on_closed(event)
        -_check_and_process_study(study_path)
        -_start_debounce_timer(study_path)
    }

    class StudyProcessor {
        -config: dict
        -fsm: FileSystemManager
        -anonymizer: DicomAnonymizer
        -contour_processor: ContourProcessor
        -burn_in_processor: BurnInProcessor
        +__init__(config, file_system_manager)
        +process_study(study_instance_uid, sender_info): bool
        -_setup_paths(study_path)
        -_validate_inputs(dcm_path, study_uid)
        -_find_struct_file(struct_dir_path)
        -_anonymize_study(dcm_path, struct_file_path)
        -_send_directory(directory_path, series_type, study_uid)
    }

    class DicomAnonymizer {
        -config: dict
        -pid_manager: PIDManager
        -tags_to_remove: list
        -tags_to_empty: list
        +__init__(anonymization_config)
        +anonymize(dicom_obj): Dataset
        +anonymize_file(filepath)
    }

    class PIDManager {
        +get_anonymized_id(original_id, original_name, study_date): str
    }

    class ContourProcessor {
        +run(dcm_path, struct_file, addition_path, debug_mode, ...): tuple
    }

    class BurnInProcessor {
        +run(addition_path)
    }

    class ReportGenerator {
        +add_line(text)
        +add_error(text)
        +write_report()
    }

    class DicomSender {
        +send_directory(directory_path): bool
    }
}

class "main" as Main {
    +main()
}

Main --> ConfigLoader : uses
Main --> DicomListener : creates
Main --> StudyProcessor : creates
Main --> FileSystemManager : creates

DicomListener o-- FileSystemManager : uses for storage
FileSystemManager *-- NewStudyEventHandler : owns
FileSystemManager ..> StudyProcessor : triggers processing via callback

StudyProcessor *-- DicomAnonymizer : uses
StudyProcessor *-- ContourProcessor : uses
StudyProcessor *-- BurnInProcessor : uses
StudyProcessor ..> ReportGenerator : creates
StudyProcessor ..> DicomSender : creates
StudyProcessor ..> FileSystemManager : uses for cleanup/quarantine

DicomAnonymizer *-- PIDManager : uses

@enduml
