@startuml
autonumber

participant "Remote Sender" as Remote
participant "DicomListener" as Listener
participant "FileSystemManager" as FSM
participant "NewStudyEventHandler" as Watcher
participant "StudyProcessor" as Processor
participant "DicomAnonymizer" as Anonymizer
participant "ContourProcessor" as Contour
participant "DicomSender" as Sender
participant "Remote Destination" as Dest

note over Listener, FSM: System Initialization (main.py) not shown for brevity

== DICOM Reception ==

Remote -> Listener: C-STORE Request (DICOM File)
activate Listener
Listener -> FSM: save_incoming_dicom(dataset, meta)
activate FSM
FSM -> FSM: Determine path (DCM/Structure)
FSM -> FSM: Write File to Disk
FSM --> Listener: Returns file_path
deactivate FSM
Listener --> Remote: C-STORE Response (Success)
deactivate Listener

== Study Detection (Debounce) ==

Watcher -> Watcher: on_created / on_modified / on_closed
activate Watcher
Watcher -> Watcher: _start_debounce_timer(study_path)
note right of Watcher: Resets timer if new files arrive
Watcher -> Watcher: Timer Expires -> _check_and_process_study()
Watcher -> FSM: is_study_being_processed(uid)
alt Study Locked / Empty / Not enough files
    Watcher -> Watcher: Abort processing
else Ready
    Watcher -> FSM: acquire_study_lock(uid)
    Watcher -> Processor: process_study(uid, sender_info)
    activate Processor
    deactivate Watcher

    == Study Processing ==

    Processor -> FSM: get_study_path(uid)
    Processor -> Processor: _setup_paths (DCM, Structure, Addition)
    Processor -> Processor: _validate_inputs

    alt Validation Success
        Processor -> Processor: _find_struct_file
        
        opt Anonymization Enabled
            Processor -> Anonymizer: anonymize_file(file) (for all files)
            activate Anonymizer
            Anonymizer --> Processor: Done
            deactivate Anonymizer
        end

        alt RTSTRUCT Found
            Processor -> ContourProcessor: run(dcm_path, struct, addition, ...)
            activate ContourProcessor
            ContourProcessor -> ContourProcessor: Generate Contours/Images
            ContourProcessor --> Processor: Success, debug_dicom_dir
            deactivate ContourProcessor
            
            Processor -> Processor: BurnInProcessor.run(addition) (Disclaimer)

            Processor -> Sender: send_directory(addition_path)
            activate Sender
            Sender -> Dest: C-STORE (Processed Files)
            Sender --> Processor: Success
            deactivate Sender

            opt Debug Series Exists
                Processor -> Sender: send_directory(debug_dicom_dir)
                activate Sender
                Sender -> Dest: C-STORE (Debug Files)
                Sender --> Processor: Success
                deactivate Sender
            end
        else No RTSTRUCT
             Processor -> Processor: Log Warning
        end

        Processor -> FSM: cleanup_study_directory(uid)
        activate FSM
        FSM -> FSM: Delete Directory
        FSM --> Processor: Done
        deactivate FSM

    else Validation Failed
        Processor -> FSM: quarantine_study(uid, reason)
    end
    
    Processor -> FSM: release_study_lock(uid)
    deactivate Processor

end

@enduml
