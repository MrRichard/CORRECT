{
  "Name": "CORRECT-PACS",
  "DicomAet": "ORTHANC",
  "DicomPort": 11114,
  "HttpPort": 8042,

  // IMPORTANT: Change these credentials before exposing to a network.
  "AuthenticationEnabled": true,
  "SslEnabled" : false,
  "RemoteAccessAllowed" : true,
  "RegisteredUsers": {
    "raduser": "correct"
  },

  "Plugins": [
    "/usr/local/share/orthanc/plugins"
  ],

  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web/",
    "EnableWado": true,
    "WadoRoot": "/wado",
    "Ssl": false
  },

  // Embedded OHIF viewer — access at http://localhost:8042/ohif/
  // Requires the DICOMweb plugin (enabled above).
  "OHIF": {
    "DataSource": "dicom-web"
  },

  "Verbose": false,

  "StorageDirectory": "/var/lib/orthanc/db",
  "IndexDirectory": "/var/lib/orthanc/db"
}
